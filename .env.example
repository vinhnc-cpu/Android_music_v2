# ── ClickHouse ────────────────────────────────────────────────────────────────
CLICKHOUSE_HOST=192.168.1.11
CLICKHOUSE_PORT=8123
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=your_password_here
CLICKHOUSE_DATABASE=android_music_v2

# ── MLflow ────────────────────────────────────────────────────────────────────
MLFLOW_TRACKING_URI=http://192.168.1.11:5000

# ── Model path (bên trong container) ─────────────────────────────────────────
MODEL_DIR=/app/models

# ── Airflow — DockerOperator cần path tuyệt đối trên HOST machine ─────────────
# Đây là đường dẫn thực tế của thư mục project trên server (không phải container).
# DockerOperator mount ./models và ./logs từ đường dẫn này vào container ML mới.
PREDICT_PROJECT_DIR=/opt/android-music-predict

# ── Airflow — Linux file permission (chạy: id -u trên server để lấy UID) ──────
AIRFLOW_UID=1000
